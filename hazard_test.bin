// ============================================================
// hazard_test.bin — Full Hazard Coverage Test
// Project : ENCS4370 - Pipelined 32-bit RISC Processor
// Author  : Amir (1231192)
// Format  : $readmemb — 32 bits per line
// Initial : R1=10, R2=20, R3=3 (set in first 3 instructions)
// ============================================================

// ── SECTION 0: Initialize base registers ─────────────────────
00101000010000000000000000001010  // ADDR   0: ADDI R1,R0,10       | R1=10
00101000100000000000000000010100  // ADDR   1: ADDI R2,R0,20       | R2=20
00101000110000000000000000000011  // ADDR   2: ADDI R3,R0,3        | R3=3 (shift amount)

// ── SECTION 1: EX-EX RAW Hazard (back-to-back dependency) ───
00000001000001001000000000000000  // ADDR   3: ADD  R4,R1,R2       | R4=10+20=30  [EX writes R4]
00000001010100001000000000000000  // ADDR   4: ADD  R5,R4,R2       | R5=30+20=50  [EX-EX forward R4]
00000101100101000100000000000000  // ADDR   5: SUB  R6,R5,R1       | R6=50-10=40  [EX-EX forward R5]

// ── SECTION 2: MEM-EX RAW Hazard (1 gap between writer/reader) ──
00000001110001001000000000000000  // ADDR   6: ADD  R7,R1,R2       | R7=30        [EX writes R7]
00001010000001001000000000000000  // ADDR   7: AND  R8,R1,R2       | R8=0         [gap]
00000010010111001000000000000000  // ADDR   8: ADD  R9,R7,R2       | R9=30+20=50  [MEM-EX forward R7]

// ── SECTION 3: WB-EX (2 gaps — no forwarding needed) ────────
00000010100001001000000000000000  // ADDR   9: ADD  R10,R1,R2      | R10=30       [WB writes R10]
00001010110001001000000000000000  // ADDR  10: AND  R11,R1,R2      | R11=0        [gap 1]
00001111000001001000000000000000  // ADDR  11: OR   R12,R1,R2      | R12=30       [gap 2]
00000011011010001000000000000000  // ADDR  12: ADD  R13,R10,R2     | R13=50       [no hazard, R10 in WB]

// ── SECTION 4: LOAD-USE Hazard (LW then immediate use → STALL) ──
00101011100000000000000000011110  // ADDR  13: ADDI R14,R0,30      | R14=30
00111011100000000000000000000000  // ADDR  14: SW   R14,0(R0)      | Mem(0)=30
00110101000000000000000000000000  // ADDR  15: LW   R4,0(R0)       | R4=Mem(0)=30 [LW writes R4]
00000001010100000100000000000000  // ADDR  16: ADD  R5,R4,R1       | R5=30+10=40  [LOAD-USE STALL → stall 1 cycle]

// ── SECTION 5: LOAD-USE with 1 gap (no stall, MEM-EX forward) ──
00110101100000000000000000000000  // ADDR  17: LW   R6,0(R0)       | R6=Mem(0)=30 [LW writes R6]
00001001110001001000000000000000  // ADDR  18: AND  R7,R1,R2       | R7=0         [gap — no stall]
00000010000110000100000000000000  // ADDR  19: ADD  R8,R6,R1       | R8=30+10=40  [MEM-EX forward R6]

// ── SECTION 6: SW reads forwarded value (EX-EX forward to store data) ──
00000010010001001000000000000000  // ADDR  20: ADD  R9,R1,R2       | R9=30        [EX writes R9]
00111010010000000000000000000100  // ADDR  21: SW   R9,4(R0)       | Mem(4)=30    [EX-EX forward R9 as store data]
00110110100000000000000000000100  // ADDR  22: LW   R10,4(R0)      | R10=30       [verify SW wrote correctly]

// ── SECTION 7: SWAP (R/W + W/R simultaneously, negedge write posedge read) ──
00101010110000000000000001100011  // ADDR  23: ADDI R11,R0,99      | R11=99
00111010110000000000000000001000  // ADDR  24: SW   R11,8(R0)      | Mem(8)=99
00101011000000000000000000110111  // ADDR  25: ADDI R12,R0,55      | R12=55
00111111000000000000000000001000  // ADDR  26: SWAP R12,8(R0)      | R12=Mem(8)=99, Mem(8)=55 [negedge W, posedge R]
00110111010000000000000000001000  // ADDR  27: LW   R13,8(R0)      | R13=55       [verify Mem(8) was written]
00000011101100000000000000000000  // ADDR  28: ADD  R14,R12,R0     | R14=99       [verify R12 was updated]

// ── SECTION 8: WAW — Write After Write (later write must win) ──
00000011110001001000000000000000  // ADDR  29: ADD  R15,R1,R2      | R15=30       [1st write to R15]
00101011110000000000000001001101  // ADDR  30: ADDI R15,R0,77      | R15=77       [2nd write to R15, must win]
00000001001111000000000000000000  // ADDR  31: ADD  R4,R15,R0      | R4=77        [must read 77, not 30]

// ── SECTION 9: R0 write protection ───────────────────────────
00101000000000000000000001100011  // ADDR  32: ADDI R0,R0,99       | R0 stays 0  [write ignored]
00000001010000000100000000000000  // ADDR  33: ADD  R5,R0,R1       | R5=10        [R0=0 confirmed]

// ── SECTION 10: ALU coverage (AND, OR, XOR, NOR, SLL, SRL, CLR) ──
00001001100001001000000000000000  // ADDR  34: AND  R6,R1,R2       | R6=10&20=0
00001101110001001000000000000000  // ADDR  35: OR   R7,R1,R2       | R7=10|20=30
00010010000001001000000000000000  // ADDR  36: XOR  R8,R1,R2       | R8=10^20=30
00010110010001001000000000000000  // ADDR  37: NOR  R9,R1,R2       | R9=~(10|20)=-31
00011010100001001100000000000000  // ADDR  38: SLL  R10,R1,R3      | R10=10<<3=80
00011110110010001100000000000000  // ADDR  39: SRL  R11,R2,R3      | R11=20>>3=2
00100011000000000000000000000000  // ADDR  40: CLR  R12            | R12=0

// ── SECTION 11: I-Type immediate (ANDI, ORI) ─────────────────
00101111010001000000000000001111  // ADDR  41: ANDI R13,R1,15      | R13=10&15=10
00110011100001000000000000000101  // ADDR  42: ORI  R14,R1,5       | R14=10|5=15

// ── SECTION 12: BEQ taken (R1==R4, 10==10) ───────────────────
00101001000000000000000000001010  // ADDR  43: ADDI R4,R0,10       | R4=10 (==R1)
01000000010100000000000000000011  // ADDR  44: BEQ  R1,R4,3        | TAKEN (10==10) skip 45,46
00101001010000000000000001100011  // ADDR  45: ADDI R5,R0,99       | SKIPPED
00101001010000000000000001100011  // ADDR  46: ADDI R5,R0,99       | SKIPPED
00101001010000000000000000110111  // ADDR  47: ADDI R5,R0,55       | R5=55 [executes]

// ── SECTION 13: BEQ not taken (R1!=R2, 10!=20) ───────────────
01000000010010000000000000000011  // ADDR  48: BEQ  R1,R2,3        | NOT TAKEN (10!=20)
00101001100000000000000001000010  // ADDR  49: ADDI R6,R0,66       | R6=66 [executes]

// ── SECTION 14: BNE taken (R1!=R2, 10!=20) ───────────────────
01000100010010000000000000000011  // ADDR  50: BNE  R1,R2,3        | TAKEN (10!=20) skip 51,52
00101001110000000000000001100011  // ADDR  51: ADDI R7,R0,99       | SKIPPED
00101001110000000000000001100011  // ADDR  52: ADDI R7,R0,99       | SKIPPED
00101001110000000000000001001101  // ADDR  53: ADDI R7,R0,77       | R7=77 [executes]

// ── SECTION 15: BNE not taken (R1==R4, 10==10) ───────────────
01000100010100000000000000000011  // ADDR  54: BNE  R1,R4,3        | NOT TAKEN (10==10)
00101010000000000000000001011000  // ADDR  55: ADDI R8,R0,88       | R8=88 [executes]

// ── SECTION 16: J unconditional ──────────────────────────────
01001000000000000000000000000011  // ADDR  56: J    3               | jump skip 57,58
00101010010000000000000001100011  // ADDR  57: ADDI R9,R0,99       | SKIPPED
00101010010000000000000001100011  // ADDR  58: ADDI R9,R0,99       | SKIPPED
00101010010000000000000000101100  // ADDR  59: ADDI R9,R0,44       | R9=44 [executes]

// ── SECTION 17: JAL + JR ─────────────────────────────────────
01001100000000000000000000000011  // ADDR  60: JAL  3               | R14=61, jumps to subroutine at 63
00101010100000000000000001100011  // ADDR  61: ADDI R10,R0,99       | Executes AFTER return!
01001000000000000000000000000011  // ADDR  62: J    3               | Jump to 65 (Escapes subroutine!)
00101010100000000000000000100001  // ADDR  63: ADDI R10,R0,33       | [Subroutine entry] R10=33
00100100001110000000000000000000  // ADDR  64: JR   R14             | PC=61

// ── SECTION 18: ALU-to-Branch Hazard (Requires 1 Stall + ID Forwarding) ──
00101011000000000000000001111011  // ADDR  65: ADDI R12,R0,123    | R12=123 (computed in EX)
01000011000000000000000000000011  // ADDR  66: BEQ  R12,R0,3      | Needs R12 in ID! STALL 1 cycle. Not taken (123!=0).
00101000000000000000000001100011  // ADDR  67: ADDI R0,R0,99      | Executes (not skipped)

// ── SECTION 19: Load-to-Branch Hazard (Requires 2 Stalls + ID Forwarding) ──
00110101010000000000000000000000  // ADDR  68: LW   R5,0(R0)      | R5=30 (from earlier SW). Ready after MEM.
01000001010000000000000000000011  // ADDR  69: BEQ  R5,R0,3       | Needs R5 in ID! STALL 2 cycles. Not taken (30!=0).
00101000000000000000000001100011  // ADDR  70: ADDI R0,R0,99      | Executes (not skipped)

// ── SECTION 20: Double Forwarding Priority Hazard ──────────────────────
00101011010000000000000000001011  // ADDR  71: ADDI R13,R0,11     | R13=11 (in MEM/WB stage)
00101011010000000000000000010110  // ADDR  72: ADDI R13,R0,22     | R13=22 (in EX/MEM stage - NEWER)
00000011101101000000000000000000  // ADDR  73: ADD  R14,R13,R0    | R14 MUST be 22. Priority check!

// ── SECTION 21: Load-to-Store Forwarding (Zero Stalls ideal) ─────────────
00110101010000000000000000000000  // ADDR  74: LW   R5,0(R0)      | R5=30
00111001010000000000000000001100  // ADDR  75: SW   R5,12(R0)     | Mem(12)=30. Should ideally not stall.
00110111110000000000000000001100  // ADDR  76: LW   R15,12(R0)    | R15=30 [verify SW wrote correctly]

// ── SECTION 22: Halt ─────────────────────────────────────────
01001000000000000000000000000000  // ADDR  77: J    0             | infinite loop (halt)
